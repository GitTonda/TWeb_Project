<div class="row mt-4">
    <div class="col-md-10 offset-md-1">
        <h2 class="fw-bold mb-4 text-center">Fan Hub: Explore Anime</h2>

        <form action="/search" method="GET" class="mb-5">
            <div class="input-group input-group-lg shadow-sm">
                <input type="text" name="q" class="form-control" placeholder="Search for Naruto, Akira, Bleach..." value="{{query}}" required>
                <button class="btn btn-primary px-4" type="submit">Search</button>
            </div>
        </form>

        {{#if errorMsg}}
            <div class="alert alert-danger">{{errorMsg}}</div>
        {{/if}}

        {{#if query}}
            <h5 class="mb-4 text-muted">Found {{results.length}} results for "{{query}}"</h5>
            <div class="row">

                {{#each results}}
                    <div class="col-md-6 mb-3">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-truncate" title="{{this.title}}">{{this.title}}</h5>

                                <div class="mt-3">
                                    <span class="badge bg-primary">{{this.type}}</span>

                                    <span class="badge bg-{{#if this.score}}success{{else}}warning{{/if}}">
                                    Score: {{#if this.score}}{{this.score}}{{else}}N/A{{/if}}
                                </span>

                                    <span class="badge bg-light text-dark border">{{this.status}}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                {{/each}}

            </div>
        {{else}}
            <div class="text-center text-muted mt-5">
                <p class="lead">Use the search bar above to query the PostgreSQL database.</p>
            </div>
        {{/if}}
    </div>
</div>